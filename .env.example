# NextGenDatabridge Platform — Environment Configuration
# Copy to .env and fill in values

# Airflow
AIRFLOW_UID=50000

# AWS / LocalStack (dev)
AWS_ACCESS_KEY_ID=localstack
AWS_SECRET_ACCESS_KEY=localstack
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566

# Production AWS (replace above with real values)
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# JWT
SECRET_KEY=change-me-in-production-use-32-random-bytes

# Database
POSTGRES_PASSWORD=changeme

# Alerting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SMTP_FROM=nextgen-databridge-noreply@company.com

# GCP (for Pub/Sub)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_PROJECT_ID=my-gcp-project

# EKS
EKS_CLUSTER_NAME=nextgen-databridge-eks

# UI
NEXTGEN_DATABRIDGE_UI_URL=http://localhost:3000
